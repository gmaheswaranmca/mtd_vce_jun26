   "source": [
    "def containsDuplicate(nums):\n",
    "    visited = set()\n",
    "    for num in nums:\n",
    "        if num in visited:\n",
    "            return True \n",
    "        visited.add(num)\n",
    "    return False \n",
    "\n",
    "print(containsDuplicate([1,2,3,1]))\n"
   ]
  }
